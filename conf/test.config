/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running minimal tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a fast and simple pipeline test.

    Use as follows:
        nextflow run nf-core/fishnetpipeline -profile test,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

process {
    resourceLimits = [
        cpus: 1,
        memory: '15.GB',
        time: '1.h'
    ]
}

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset to check pipeline function'

    // Input data
    input                       = "${projectDir}/data/BMI/0-BMI.csv"
    input_modules               = "${projectDir}/data/modules_test"
    outdir                      = 'results'
    bonferroni_alpha            = 0.05
    FDR_threshold               = 0.05
    percentile_threshold        = 99
    trait                       = 'BMI'     // this will eventually need to be inferred from input
    pipeline                    = 'llfsTWASOR'
    numTests                    = 14172
    geneColName                 = 'Genes'
    pvalColName                 = 'p_vals'
    GO_summaries_path           = 'GO_summaries'
    masterSummaries_path        = 'masterSummaries'

}

singularity {
    enabled = true
    autoMounts = true
    cacheDir = "singularity_images"
    runOptions = "-B ${projectDir}:${projectDir}"
}
